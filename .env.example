# PostgreSQL（Docker Compose 用）
POSTGRES_USER=ow_user
POSTGRES_PASSWORD=ow_password
POSTGRES_DB=ow_custom_app

# Go バックエンドからの接続用URL（Step 2 以降で使用）
DATABASE_URL=postgres://ow_user:ow_password@localhost:5433/ow_custom_app?sslmode=disable

# Google OAuth（Step 5 で設定）
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URL=http://localhost:8080/api/v1/auth/google/callback
